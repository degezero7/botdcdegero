version: "3.8"

services:
  bot:
    image: python:3.13-slim
    container_name: bot-gezero
    working_dir: /app
    volumes:
      - /home/ubuntu/botdcdegero:/app
    command: sh -c "pip install --no-cache-dir -r requirements.txt && python main.py"
    env_file:
      - /app/.env
    restart: unless-stopped
